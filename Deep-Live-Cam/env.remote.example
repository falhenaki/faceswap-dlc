# Copy to env.remote (gitignored), then:
#   set -a && source /path/to/Deep-Live-Cam/env.remote && set +a && python run.py
#
# TWO DIFFERENT "KEYS" (easy to mix up):
#
# 1) RunPod dashboard API key (rpa_...) — ONLY for RunPod's own tools (API/CLI to manage pods).
#    Deep-Live-Cam does NOT read this. You can ignore it for swapping.
#
# 2) Swap password YOU invent — same random string in two places: Mac (below) + GPU pod env
#    SWAP_SERVICE_API_KEY. Example:  openssl rand -hex 32
#    This is NOT your RunPod rpa_ key (don't reuse that here).

# --- Mac only (for python run.py) ---
# HTTPS URL from the pod: Connect → HTTP / Proxy (no path at end)
DLC_REMOTE_SWAP_URL=https://YOUR_SUBDOMAIN.proxy.runpod.net
# Same invented secret as SWAP_SERVICE_API_KEY on the pod
DLC_REMOTE_SWAP_API_KEY=paste-output-of-openssl-rand-hex-32
# Must match inswapper crop (128 for inswapper_128.onnx)
DLC_REMOTE_SWAP_INPUT_SIZE=128
# Optional
# DLC_REMOTE_SWAP_TIMEOUT=30

# --- GPU pod (RunPod → Pod → Environment, or shell before uvicorn) ---
# SWAP_SERVICE_API_KEY=same-string-as-DLC_REMOTE_SWAP_API_KEY-above
# INSWAPPER_MODEL_PATH=/workspace/models/inswapper_128.onnx

# --- Provision the pod with Terraform (instead of the RunPod UI) ---
# Repo must be pushed to GitHub (or another git URL) so the pod can clone it.
#   cd Deep-Live-Cam/remote-swap-server/terraform
#   cp terraform.tfvars.example terraform.tfvars   # edit swap_code_git_url + swap_service_api_key
#   export RUNPOD_API_KEY=rpa_...
#   terraform init && terraform apply
#   terraform output -raw dlc_remote_swap_url   # put that in DLC_REMOTE_SWAP_URL above
#
# --- SSH into the pod (RunPod proxy; suffix is NOT optional) ---
# Username = <podId>-<8-char-suffix> from the pod page → Connect → SSH (copy their command).
# Example shape:
#   ssh au6vyb7r64svv6-644117b2@ssh.runpod.io -i ~/.ssh/ssh_id_runpod
# The public key for that private key must be in RunPod → Account settings → SSH Public Keys.
